	"environment": {
		"ENCRYPTION_KEY": "{{options.encryption_key}}",
		"DATABASE_USER": "{{options.database_user}}",
		"DATABASE_PASS": "{{options.database_pass}}",
		"DATABASE_NAME": "{{options.database_name}}",
		"DATABASE_HOST": "{{options.database_host}}",
		"MQTT_HOST": "{{options.mqtt_host}}",
		"MQTT_USERNAME": "{{options.mqtt_user}}",
		"MQTT_PASSWORD": "{{options.mqtt_password}}",
		"TZ": "{{options.TZ}}"
	},
	"image": "ghcr.io/teslamate-org/teslamate-{arch}",
	"ingress": true,
	"ingress_stream": true,
	"map": ["config:rw"],
	"name": "TeslaMate",
	"options": {
		"TZ": "Europe/Amsterdam",
		"database_user": "teslamate",
		"database_pass": "changeme",
		"database_name": "teslamate",
		"database_host": "localhost",
		"mqtt_host": "localhost",
		"mqtt_user": "",
		"mqtt_password": "",
		"encryption_key": ""
	},
	"panel_admin": false,
	"panel_icon": "mdi:car-connected",
	"ports": {
		"4000/tcp": 4000,
		"3000/tcp": 3000,
		"5432/tcp": 5432,
		"1883/tcp": 1883
	},
	"ports_description": {
		"4000/tcp": "TeslaMate web interface",
		"3000/tcp": "Grafana dashboard",
		"5432/tcp": "PostgreSQL database",
		"1883/tcp": "Mosquitto MQTT broker"
	},
	"schema": {
		"TZ": "str",
		"database_user": "str",
		"database_pass": "password",
		"database_name": "str",
		"database_host": "str",
		"mqtt_host": "str",
		"mqtt_user": "str?",
		"mqtt_password": "password?",
		"encryption_key": "password"
	},
	"slug": "teslamate",
	"udev": true,
	"url": "https://github.com/bruvv/hassio-addons/tree/main/teslamate",
	"version": "1.0.0"
}
